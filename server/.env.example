# ── Database ──────────────────────────────────
DB_NAME=bob
DB_USER=bob
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# ── Redis ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── SearXNG ────────────────────────────────────
SEARXNG_BASE_URL=http://localhost:8888

# ── Django ─────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
