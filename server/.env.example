DJANGO_SUPERUSER_PASSWORD=changeme

# ── Frontend URL (for CORS) ────────────────────
FRONTEND_URL=http://localhost:3000

# ── Cloudinary ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── API Keys ───────────────────────────────────
OPENROUTER_API_KEY=
REVERSE_IMAGE=

# ── Monitoring ────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin